# Firebase (obrigatório)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# Bucket de Storage (*.firebasestorage.app ou *.appspot.com — NUNCA *.firebaseapp.com, que é authDomain)
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase App Check (reCAPTCHA Enterprise). Obrigatório para regras de produção.
# Console: Firebase > App Check > registrar app Web > reCAPTCHA Enterprise
# Checklist produção (Vercel + Firebase):
# - NEXT_PUBLIC_FIREBASE_APP_CHECK_RECAPTCHA_SITE_KEY em Production (redeploy após adicionar)
# - App Web registrado em Firebase App Check com reCAPTCHA Enterprise
# - Domínios waitless.solutions e www.waitless.solutions na site key (Google Cloud)
# - NÃO definir NEXT_PUBLIC_FIREBASE_APP_CHECK_DEBUG_TOKEN em Production
NEXT_PUBLIC_FIREBASE_APP_CHECK_RECAPTCHA_SITE_KEY=
# Dev: registre um debug token no console e cole aqui
NEXT_PUBLIC_FIREBASE_APP_CHECK_DEBUG_TOKEN=
# Dev: exibe aviso de proteção do navegador no admin em localhost
# NEXT_PUBLIC_SHOW_PROTECTION_ADVISORY=true

# Upload de logo no servidor — rode: npm run setup:service-account
# FIREBASE_SERVICE_ACCOUNT_PATH=secrets/firebase-service-account.json
# Produção/Vercel: cole o JSON inteiro em uma linha (sem quebras). Obrigatório para 2FA, exclusão de conta e upload de logo. Ex.:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# WhatsApp Business API (opcional — v0.3)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# Habilita botão "API" no card Aguardando (opcional)
NEXT_PUBLIC_WHATSAPP_API_ENABLED=false

# URL pública do app (links da fila no WhatsApp). Obrigatória na Vercel.
# Ex.: https://www.waitless.solutions
# Em dev, localhost não vira link clicável no WhatsApp.
# Na Vercel, VERCEL_URL é usado como fallback server-side se esta variável estiver vazia.
NEXT_PUBLIC_APP_URL=

# Dados legais / LGPD (rodapé, políticas e canal do titular)
# Defina os valores reais na Vercel — placeholders abaixo são apenas para desenvolvimento local.
NEXT_PUBLIC_LEGAL_RAZAO_SOCIAL=Controlador Waitless
NEXT_PUBLIC_LEGAL_CPF=000.000.000-00
NEXT_PUBLIC_LEGAL_ADDRESS=Seu endereço completo
NEXT_PUBLIC_LEGAL_EMAIL_LGPD=seu-email@exemplo.com
# E-mail de suporte ao cliente (Central de Ajuda, billing). Fallback: NEXT_PUBLIC_LEGAL_EMAIL_LGPD
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_LEGAL_DPO_NAME=Encarregado Waitless
NEXT_PUBLIC_LEGAL_TECH_LEAD=Responsável técnico Waitless
# CNPJ opcional — apenas se o operador da plataforma for PJ
NEXT_PUBLIC_LEGAL_CNPJ=

# 2FA por e-mail (opcional — em dev o código OTP aparece no log do servidor)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Stripe — assinaturas (Essencial/Pro, BR e US)
# 1) Cole STRIPE_SECRET_KEY (sk_test_...) abaixo
# 2) Rode: npm run setup:stripe-prices  (cria produtos/preços e preenche STRIPE_PRICE_*)
# 3) Dev webhook: stripe listen --forward-to localhost:3000/api/billing/webhook
# 4) Rode: npm run verify:stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Opcional — Checkout hospedado não usa no código atual
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Brasil (BRL) — checkout com cartão, boleto e parcelamento em até 12x
STRIPE_PRICE_BR_ESSENTIAL_WEEK=
STRIPE_PRICE_BR_ESSENTIAL_MONTH=
STRIPE_PRICE_BR_ESSENTIAL_YEAR=
STRIPE_PRICE_BR_PRO_WEEK=
STRIPE_PRICE_BR_PRO_MONTH=
STRIPE_PRICE_BR_PRO_YEAR=
# EUA (USD)
STRIPE_PRICE_US_ESSENTIAL_WEEK=
STRIPE_PRICE_US_ESSENTIAL_MONTH=
STRIPE_PRICE_US_ESSENTIAL_YEAR=
STRIPE_PRICE_US_PRO_WEEK=
STRIPE_PRICE_US_PRO_MONTH=
STRIPE_PRICE_US_PRO_YEAR=
# Brasil (opcional): habilite no Dashboard Stripe (live) antes de ligar
# https://dashboard.stripe.com/settings/payment_methods
# STRIPE_BR_BOLETO_ENABLED=true
# STRIPE_BR_INSTALLMENTS_ENABLED=true

# PIX Brasil — Asaas (assinaturas recorrentes com billingType PIX)
# 1) Crie conta em https://www.asaas.com e gere API key em Integrações
# 2) Webhook: https://www.waitless.solutions/api/billing/pix/webhook
#    Eventos: PAYMENT_RECEIVED, PAYMENT_CONFIRMED, PAYMENT_OVERDUE
#    Header asaas-access-token = ASAAS_WEBHOOK_TOKEN
# 3) Produção: chave em https://www.asaas.com → Integrações → API (NÃO use sandbox.asaas.com)
#    Webhook produção: https://www.waitless.solutions/api/billing/pix/webhook
#    Cadastre chave Pix em Asaas → Pix → Minhas chaves
# 4) Sandbox (só homologação): ASAAS_SANDBOX=true + chave do sandbox.asaas.com
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
# ASAAS_SANDBOX=true
# ASAAS_PIX_ENABLED=true
NEXT_PUBLIC_BILLING_PIX_ENABLED=false

# Google Ads — tag base em todas as páginas; conversão no cadastro (/admin/auth signup)
# Tag base: AW-18269940292 | Conversão: Google Ads → Metas → Conversões → rótulo após a barra
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-18269940292
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=8GyJCNGB4cUcEMTU5ldE

# Painel administrativo da plataforma (super-admin)
# E-mail único autorizado a acessar /platform
PLATFORM_ADMIN_EMAIL=admin@exemplo.com
# Segredo para cookie de sessão httpOnly (mín. 32 caracteres). Ex.: openssl rand -base64 32
PLATFORM_SESSION_SECRET=
# Conceder claim: npm run grant:platform-admin admin@exemplo.com

# E2E local (TestSprite — defina apenas em .env.local, nunca commite)
# TESTSPRITE_EMAIL=
# TESTSPRITE_PASSWORD=
