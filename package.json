{
  "name": "waitless",
  "version": "0.3.0",
  "private": false,
  "engines": {
    "node": "20"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "process:logo-clara": "node scripts/process-logo-clara.mjs",
    "setup:storage-cors": "node scripts/setup-storage-cors.mjs",
    "setup:auth-domain": "node scripts/add-firebase-auth-domain.mjs www.waitless.solutions",
    "setup:auth-domains": "node scripts/add-firebase-auth-domain.mjs www.waitless.solutions && node scripts/add-firebase-auth-domain.mjs waitless.solutions",
    "setup:google-oauth": "node scripts/setup-google-oauth.mjs",
    "verify:google-oauth": "node scripts/verify-google-oauth-setup.mjs",
    "setup:stripe": "node scripts/setup-stripe.mjs",
    "setup:stripe-prices": "node scripts/setup-stripe-prices.mjs",
    "verify:stripe": "node scripts/verify-stripe-setup.mjs",
    "setup:asaas-pix": "node scripts/setup-asaas-pix.mjs",
    "setup:firebase-storage": "node scripts/setup-firebase-storage.mjs",
    "setup:service-account": "node scripts/setup-service-account.mjs",
    "setup:app-check-debug-token": "node scripts/setup-app-check-debug-token.mjs",
    "seed:testsprite": "node scripts/seed-testsprite-e2e.mjs",
    "delete:testsprite-user": "node scripts/delete-testsprite-user.mjs",
    "grant:platform-admin": "node scripts/grant-platform-admin.mjs",
    "set:platform-admin-password": "node scripts/set-platform-admin-password.mjs",
    "backfill:billing-transactions": "node scripts/backfill-billing-transactions.mjs",
    "firebase:deploy:storage": "npx firebase-tools@latest deploy --only storage --project waitless-queue-saas",
    "test:rules": "npx firebase-tools@latest emulators:exec --only firestore --project waitless-rules-test \"npm run test:rules:run\"",
    "test:rules:run": "vitest run tests/firestore.rules.test.ts"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "clsx": "^2.1.1",
    "firebase": "^12.14.0",
    "firebase-admin": "^13.4.0",
    "framer-motion": "^12.40.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "sharp": "^0.34.2",
    "stripe": "^22.2.1",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "form-data": "^2.5.6",
    "uuid": "^11.1.1",
    "protobufjs": "^7.6.3",
    "postcss": "^8.5.10"
  }
}
